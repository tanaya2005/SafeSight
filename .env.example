MONGO_URI=
JWT_SECRET=
PORT=5000
NODE_ENV=development

# Camera Configuration
# Set these based on your system's camera indices
# Run 'python ai-engine/test_cameras.py' to find available cameras
CAM_PPE_INDEX=1          # Camera for PPE Detection (CAM-1)
CAM_ZONE_INDEX=2         # Camera for Zone Monitoring (CAM-2)
CAM_WEBCAM_INDEX=0       # Default webcam index

# Voice Alert Configuration
# Language options: en (English), hi (Hindi), mr (Marathi)
VOICE_ALERT_LANG=en      # Default language for voice alerts

